@page "/"

<PageTitle>LoanShark: Home</PageTitle>
<!-- Page Background -->
<div class="pageStyle h-100 d-flex justify-content-center">
    <div class="row row-cols-1 row-cols-xl-2 container-xxl h-100">
        <div class="col d-flex flex-column justify-content-xl-center order-xl-first order-last">
            <div class="title">Loan Shark: Your fast accurate loan calculator</div>
            <div class="subTitle">Simplifying Loan Calculations for Clear Financial Decisions</div>
            <p>
                Loan Shark is a simple, easy-to-use loan calculator that helps you make informed financial decisions.
                Whether you're looking to buy a new car, a house, or just need a personal loan, Loan Shark can help you
                calculate your monthly payments, interest rates, and total loan costs.
            </p>
            <div class="mt-3">
                <button type="button" class="btn btn-primary rounded">Try it Out!</button>
            </div>
            <div class="mt-3">
                Built with pride using:
                <div class="hstack my-2">
                    <div><i class="devicons devicon-csharp-plain colored me-1"></i></div>
                    <div><i class="devicons devicon-bootstrap-plain colored me-1"></i></div>
                    <div><i class="devicons devicon-javascript-plain colored me-1"></i></div>
                    <div><i class="devicons devicon-html5-plain colored me-1"></i></div>
                    <div><i class="devicons devicon-css3-plain colored me-1"></i></div>
                </div>
            </div>
        </div>
        <div class="col d-flex flex-column justify-content-center">
            <img src="images/LoanShark.png" class="img-fluid" />
        </div>
    </div>
</div>